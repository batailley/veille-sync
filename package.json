{
  "name": "veille-sync",
  "version": "1.0.0",
  "description": "Watcher iCloud Clippings → Claude API → Anytype",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test:mcp": "tsx test-mcp.ts",
    "process": "tsx process.ts --provider gemini",
    "process:claude": "tsx process.ts --provider claude",
    "api": "tsx api-server.ts",
    "ui": "cd ui && pnpm dev",
    "ui:install": "cd ui && pnpm install",
    "studio": "concurrently -n api,ui -c cyan,magenta \"pnpm api\" \"pnpm ui\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "chokidar": "^3.6.0",
    "dotenv": "^16.4.5",
    "gray-matter": "^4.0.3",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0"
  }
}
